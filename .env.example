# ── AI provider ── openai | anthropic | gemini | bedrock | fake
AI_PROVIDER=openai
OPENAI_MODEL=gpt-4o           # model id for the selected provider
OPENAI_MODEL_INFO=gpt-4o-mini # cheaper model for info/warning severity (openai only)
SLACK_WEBHOOK_URL=

# OpenAI (set OPENAI_BASE_URL for Azure OpenAI / a proxy)
OPENAI_API_KEY=
OPENAI_BASE_URL=

# Anthropic (direct API; or use Claude via Bedrock below to skip this)
ANTHROPIC_API_KEY=

# Gemini — Vertex uses a service-account JSON; GLA uses an API key
GOOGLE_GENAI_USE_VERTEXAI=true
GOOGLE_CLOUD_PROJECT=
GOOGLE_CLOUD_LOCATION=us-central1
GOOGLE_SA_JSON=              # SA JSON *content* (materialised to a file); or set the path below
GOOGLE_APPLICATION_CREDENTIALS=
GEMINI_API_KEY=             # only for GLA mode (GOOGLE_GENAI_USE_VERTEXAI=false)

# AWS Bedrock — on EKS use the pod IAM role (IRSA); locally use AWS_PROFILE / SSO
AWS_REGION=ap-south-1
AWS_ROLE_ARN=              # optional cross-account role to assume

# Boot-default data-source endpoints (used when an environment leaves a source
# unset, or for a single-env deploy with no endpoint registry).
PROMETHEUS_URL=http://prometheus-sit.dozee.int
LOKI_URL=http://host.docker.internal:3100
# Named endpoint registry (Prometheus/Loki/Kubernetes/AWS + auth) and the
# environment → endpoint-ref map. Both managed from the Web UI (Settings);
# these files are the local seed/fallback. Alertmanager posts to /webhook/<env>
# (bare /webhook uses the "default" environment).
ENDPOINTS_CONFIG_PATH=/app/config/endpoints.yaml
ENVIRONMENTS_CONFIG_PATH=/app/config/environments.yaml
# CloudWatch MCP (AWS metrics/logs per environment). Empty disables it.
CLOUDWATCH_MCP_URL=http://127.0.0.1:8005/mcp
# Multi-context kubeconfig for cross-cluster Kubernetes (kube_context endpoints).
# KUBECONFIG=/var/secrets/kube/config
REDIS_URL=redis://redis:6379/0
AGENT_PORT=8080

# Optional safety filter (regex). Empty = accept all alertnames routed by Alertmanager.
ALLOWED_ALERTNAMES=
DEDUP_TTL_SECONDS=900
INVESTIGATION_MAX_WORKERS=8
RUNBOOK_BASE_URL=https://wiki.dozee.internal/runbooks
ALERT_CATALOG_PATH=/app/config/alert_catalog.yaml
RECURRENCE_LOOKBACK_DAYS=7
RECURRENCE_THRESHOLD=3
LOG_LEVEL=INFO

# Web UI — browser uses same-origin /api proxy unless NEXT_PUBLIC_API_URL is set
API_URL=http://localhost:8080
NEXT_PUBLIC_API_URL=
NEXT_PUBLIC_ADMIN_TOKEN=          # must match ADMIN_TOKEN when auth is enabled
