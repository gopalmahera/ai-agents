# Dozee Alert Intelligence (DAI) — environment
#
# Docker:
#   Dev (hot reload): docker compose -f docker-compose.dev.yml up --build
#   Prod:             docker compose up --build

API_PORT=4000
NEXT_PUBLIC_API_URL=
# Server-side proxy target for Next.js rewrites (Docker: http://api:4000)
API_INTERNAL_URL=http://localhost:4000
ADMIN_TOKEN=
NEXT_PUBLIC_ADMIN_TOKEN=

MONGO_URL=mongodb://mongo:27017
MONGO_DB=dai

REDIS_URL=redis://redis:6379/0
BULLMQ_PREFIX=dai

LOGS_DIR=/app/logs
CONFIG_ROOT=/app/config

AGENT_ID=default
AGENT_TOKEN=
API_WS_URL=http://api:4000
API_HTTP_URL=http://api:4000
AGENT_PORT=8080
ENABLE_FLASK_WEBHOOKS=false

AI_PROVIDER=openai
OPENAI_MODEL=gpt-4o
OPENAI_MODEL_INFO=gpt-4o-mini
SLACK_WEBHOOK_URL=
OPENAI_API_KEY=
OPENAI_BASE_URL=
ANTHROPIC_API_KEY=
GOOGLE_GENAI_USE_VERTEXAI=true
GOOGLE_CLOUD_PROJECT=
GOOGLE_CLOUD_LOCATION=us-central1
GOOGLE_SA_JSON=
GOOGLE_APPLICATION_CREDENTIALS=
GEMINI_API_KEY=
AWS_REGION=ap-south-1
AWS_ROLE_ARN=

PROMETHEUS_URL=http://prometheus-sit.dozee.int
LOKI_URL=http://host.docker.internal:3100
ENDPOINTS_CONFIG_PATH=/app/config/endpoints.yaml
ENVIRONMENTS_CONFIG_PATH=/app/config/environments.yaml
CLOUDWATCH_MCP_URL=http://127.0.0.1:8005/mcp

ALLOWED_ALERTNAMES=
DEDUP_TTL_SECONDS=900
INVESTIGATION_MAX_WORKERS=8
RUNBOOK_BASE_URL=https://wiki.dozee.internal/runbooks
ALERT_CATALOG_PATH=/app/config/alert_catalog.yaml
RECURRENCE_LOOKBACK_DAYS=7
RECURRENCE_THRESHOLD=3
LOG_LEVEL=INFO
