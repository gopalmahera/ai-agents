# ── Platform (five-part architecture) ──
# 1. Web (Next.js UI)  2. API (NestJS)  3. Agent (Python)  4. Mongo  5. Redis

# NestJS API
API_PORT=4000
NEXT_PUBLIC_API_URL=http://localhost:4000
ADMIN_TOKEN=
NEXT_PUBLIC_ADMIN_TOKEN=

# MongoDB — settings + alert event history
MONGO_URL=mongodb://mongo:27017
MONGO_DB=alert_agent

# Redis — dedup, counters, BullMQ, Socket.IO adapter
REDIS_URL=redis://redis:6379/0
BULLMQ_PREFIX=ai-agent

# Agent WebSocket worker (outbound to API)
AGENT_ID=default
AGENT_TOKEN=
API_WS_URL=http://api:4000
API_HTTP_URL=http://api:4000
AGENT_PORT=8080
ENABLE_FLASK_WEBHOOKS=false

# Shared logs volume (API + agent)
LOGS_DIR=/app/logs
CONFIG_ROOT=/app/config

# ── AI provider ── openai | anthropic | gemini | bedrock | fake
AI_PROVIDER=openai
OPENAI_MODEL=gpt-4o
OPENAI_MODEL_INFO=gpt-4o-mini
SLACK_WEBHOOK_URL=
OPENAI_API_KEY=
OPENAI_BASE_URL=
ANTHROPIC_API_KEY=
GOOGLE_GENAI_USE_VERTEXAI=true
GOOGLE_CLOUD_PROJECT=
GOOGLE_CLOUD_LOCATION=us-central1
GOOGLE_SA_JSON=
GOOGLE_APPLICATION_CREDENTIALS=
GEMINI_API_KEY=
AWS_REGION=ap-south-1
AWS_ROLE_ARN=

# Boot-default data sources (environment registry overrides in UI)
PROMETHEUS_URL=http://prometheus-sit.dozee.int
LOKI_URL=http://host.docker.internal:3100
ENDPOINTS_CONFIG_PATH=/app/config/endpoints.yaml
ENVIRONMENTS_CONFIG_PATH=/app/config/environments.yaml
CLOUDWATCH_MCP_URL=http://127.0.0.1:8005/mcp

ALLOWED_ALERTNAMES=
DEDUP_TTL_SECONDS=900
INVESTIGATION_MAX_WORKERS=8
RUNBOOK_BASE_URL=https://wiki.dozee.internal/runbooks
ALERT_CATALOG_PATH=/app/config/alert_catalog.yaml
RECURRENCE_LOOKBACK_DAYS=7
RECURRENCE_THRESHOLD=3
LOG_LEVEL=INFO

# Alertmanager → POST http://api:4000/api/v1/webhook/<env>
