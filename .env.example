OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o
OPENAI_MODEL_INFO=gpt-4o-mini
AI_PROVIDER=openai
SLACK_WEBHOOK_URL=

PROMETHEUS_URL=http://prometheus-sit.dozee.int
LOKI_URL=http://host.docker.internal:3100
REDIS_URL=redis://redis:6379/0

# Optional safety filter (regex). Empty = accept all alertnames routed by Alertmanager.
ALLOWED_ALERTNAMES=
DEDUP_TTL_SECONDS=900
INVESTIGATION_MAX_WORKERS=8
RUNBOOK_BASE_URL=https://wiki.dozee.internal/runbooks
ALERT_CATALOG_PATH=/app/config/alert_catalog.yaml
RECURRENCE_LOOKBACK_DAYS=7
RECURRENCE_THRESHOLD=3
LOG_LEVEL=INFO

# Web UI
ADMIN_TOKEN=                          # Bearer token for /api/* endpoints (leave blank to disable auth in dev)
NEXT_PUBLIC_API_URL=http://localhost:5001   # override in prod: http://alert-agent:5001
